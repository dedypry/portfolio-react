// Prisma schema — single source of truth for all admin-managed content.
// i18n strategy: JSON column `translations` holding { en: {...}, id: {...} }.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ExperienceType {
  FULL_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(ADMIN)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  blogs        Blog[]
}

/// Singleton — only one row exists. Hero/about copy + contact info.
model Profile {
  id           String   @id @default(cuid())
  name         String
  initials     String
  email        String
  phone        String
  location     String
  linkedin     String
  github       String
  available    Boolean  @default(true)

  /// { en: { role, tagline, description, headlineLine1, headlineHighlight }, id: {...} }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Experience {
  id           String         @id @default(cuid())
  company      String
  location     String
  period       String
  type         ExperienceType
  stack        String[]       @default([])
  order        Int            @default(0)

  /// { en: { role, highlights[] }, id: { role, highlights[] } }
  translations Json

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([order])
}

model Education {
  id           String   @id @default(cuid())
  school       String
  location     String
  period       String
  order        Int      @default(0)

  /// { en: { degree, description? }, id: { degree, description? } }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
}

model Project {
  id           String   @id @default(cuid())
  category     String
  accent       String?
  link         String?
  stack        String[] @default([])
  coverImage   String?
  order        Int      @default(0)
  featured     Boolean  @default(false)

  /// { en: { name, tagline, description }, id: {...} }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
  @@index([featured])
}

model SkillGroup {
  id           String   @id @default(cuid())
  key          String   @unique
  order        Int      @default(0)

  /// { en: { title }, id: { title } }
  translations Json

  skills       Skill[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
}

model Skill {
  id           String     @id @default(cuid())
  name         String
  proficiency  Int?
  order        Int        @default(0)

  groupId      String
  group        SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([groupId, order])
}

model Blog {
  id           String     @id @default(cuid())
  slug         String     @unique
  status       BlogStatus @default(DRAFT)
  publishedAt  DateTime?
  coverImage   String?
  readingTime  Int?
  tags         String[]   @default([])

  authorId     String
  author       User       @relation(fields: [authorId], references: [id])

  /// { en: { title, excerpt, content }, id: { title, excerpt, content } }
  translations Json

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
}
