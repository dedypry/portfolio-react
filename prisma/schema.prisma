// Prisma schema — single source of truth for all admin-managed content.
// i18n strategy: JSON column `translations` holding { en: {...}, id: {...} }.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

enum ExperienceType {
  FULL_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum MessageStatus {
  UNREAD
  READ
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         Role      @default(ADMIN)
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  blogs        Blog[]
}

/// Singleton — only one row exists. Hero/about copy + contact info.
model Profile {
  id           String   @id @default(cuid())
  name         String
  initials     String
  email        String
  phone        String
  location     String
  linkedin     String
  github       String
  available    Boolean  @default(true)

  /// { en: { role, tagline, description, headlineLine1, headlineHighlight }, id: {...} }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Experience {
  id           String         @id @default(cuid())
  company      String
  location     String
  period       String
  type         ExperienceType
  stack        String[]       @default([])
  order        Int            @default(0)

  /// { en: { role, highlights[] }, id: { role, highlights[] } }
  translations Json

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([order])
}

model Education {
  id           String   @id @default(cuid())
  school       String
  location     String
  period       String
  order        Int      @default(0)

  /// { en: { degree, description? }, id: { degree, description? } }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
}

model Project {
  id           String   @id @default(cuid())
  category     String
  accent       String?
  link         String?
  stack        String[] @default([])
  coverImage   String?
  order        Int      @default(0)
  featured     Boolean  @default(false)

  /// { en: { name, tagline, description }, id: {...} }
  translations Json

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
  @@index([featured])
}

model SkillGroup {
  id           String   @id @default(cuid())
  key          String   @unique
  order        Int      @default(0)

  /// { en: { title }, id: { title } }
  translations Json

  skills       Skill[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([order])
}

model Skill {
  id           String     @id @default(cuid())
  name         String
  proficiency  Int?
  order        Int        @default(0)

  groupId      String
  group        SkillGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([groupId, order])
}

model Blog {
  id            String     @id @default(cuid())
  slug          String     @unique
  status        BlogStatus @default(DRAFT)
  publishedAt   DateTime?
  coverImage    String?
  readingTime   Int?
  tags          String[]   @default([])

  // Engagement counters. Incremented via dedicated API routes; never edited
  // by hand from the admin form to keep the numbers honest.
  viewCount     Int        @default(0)
  favoriteCount Int        @default(0)
  shareCount    Int        @default(0)

  authorId      String
  author        User       @relation(fields: [authorId], references: [id])

  /// { en: { title, excerpt, content }, id: { title, excerpt, content } }
  translations  Json

  comments      Comment[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([slug])
}

/// Direct messages from visitors via /contact. These are private (never
/// shown publicly) — they land in the admin inbox where they can be read,
/// marked read, archived, or deleted. Anonymous: name + email + body.
model Message {
  id          String        @id @default(cuid())
  name        String
  email       String
  subject     String?
  body        String

  status      MessageStatus @default(UNREAD)

  // Same anti-abuse signals as comments: opaque session id + hashed IP.
  sessionId   String?
  ipHash      String?
  userAgent   String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  readAt      DateTime?

  @@index([status, createdAt])
}

/// Visitor comments on blog posts. Anonymous (name + email, no account
/// needed). All new comments default to PENDING — admin must approve them
/// from /admin/comments before they show up publicly.
///
/// Nested replies use the self-relation `parent` / `replies`. Deleting a
/// parent cascades to its children so we never leave orphaned threads.
model Comment {
  id           String        @id @default(cuid())
  blogId       String
  blog         Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)

  parentId     String?
  parent       Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]     @relation("CommentReplies")

  authorName   String
  authorEmail  String
  authorWebsite String?
  body         String

  status       CommentStatus @default(PENDING)

  // True for replies generated automatically by the AI assistant after a
  // visitor's comment. We never run AI moderation/reply on AI replies, so
  // this flag also breaks any potential auto-reply loops.
  isAiReply    Boolean       @default(false)
  aiModel      String?

  // Light-touch metadata for moderation. Cookie session id helps us flag
  // bursts from the same browser; IP is captured best-effort (will be the
  // proxy IP behind Nginx unless forwarded headers are set).
  sessionId    String?
  ipHash       String?
  userAgent    String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([blogId, status, createdAt])
  @@index([parentId])
  @@index([status, createdAt])
  @@index([isAiReply])
}
