# Copy this file to `.env.local` (dev) or `.env.production` (prod) and fill in real values.
# `.env*` files are git-ignored (see .gitignore).

# ─── Site URL ──────────────────────────────────────────────
# Public URL of the site. NO trailing slash.
# Dev:  http://localhost:3000
# Prod: https://dedypry.site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Auth.js v5 (REQUIRED for /admin to work) ─────────────
# Generate with: openssl rand -base64 32
# This MUST be a long random string and MUST be different per environment.
# If you change it, every existing logged-in session is invalidated.
AUTH_SECRET=

# Public URL Auth.js uses to build callback URLs. Same as NEXT_PUBLIC_SITE_URL.
# In production this MUST be https://... so Secure cookies work.
AUTH_URL=http://localhost:3000

# When running behind a reverse proxy (Nginx, aaPanel, Vercel, Cloudflare),
# Auth.js needs to trust the forwarded Host header.
AUTH_TRUST_HOST=true

# ─── PostgreSQL (Prisma) ───────────────────────────────────
# Local:  postgresql://USER:PASSWORD@localhost:5432/DBNAME?schema=public
# Prod:   point to your managed Postgres or VM-local Postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dedypry?schema=public

# ─── Initial admin (used by `npm run db:seed`) ─────────────
# These only matter on first seed. Change ADMIN_PASSWORD via the UI/db
# afterwards — the seeded value is not re-applied on later seeds.
ADMIN_EMAIL=admin@dedypry.site
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Dedy Priyatna

# ─── Gemini AI (chat feature) ──────────────────────────────
# Free Gemini API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
